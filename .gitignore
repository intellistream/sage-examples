# ============================================================================
# .gitignore for SAGE Examples
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/
.conda/

# ----------------------------------------------------------------------------
# IDEs and editors
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------------------------
# Testing and coverage
# ----------------------------------------------------------------------------
.pytest_cache/
.benchmarks/
.sage/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ----------------------------------------------------------------------------
# Distribution and build
# ----------------------------------------------------------------------------
dist/
build/
*.egg-info/

# ----------------------------------------------------------------------------
# Documentation
# ----------------------------------------------------------------------------
docs/_build/
docs/.doctrees/
site/

# ----------------------------------------------------------------------------
# Logs and temporary files
# ----------------------------------------------------------------------------
*.log
pytest.log
test.log
.sage/test/
*.tmp
*.bak
*.swp

# ----------------------------------------------------------------------------
# Data files (可能包含大文件或敏感数据)
# ----------------------------------------------------------------------------
# Uncomment if needed:
# *.mp4
# *.avi
# *.mov
# *.mkv
# *.dicom
# *.dcm

# ----------------------------------------------------------------------------
# Model files (通常很大，不应提交到仓库)
# ----------------------------------------------------------------------------
*.pth
*.pt
*.ckpt
*.h5
*.pb
*.onnx
models/
checkpoints/

# ----------------------------------------------------------------------------
# Temporary improvement docs
# ----------------------------------------------------------------------------
*_IMPROVEMENTS.md
IMPROVEMENTS.md

# ----------------------------------------------------------------------------
# Jupyter Notebooks
# ----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----------------------------------------------------------------------------
# MacOS
# ----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ----------------------------------------------------------------------------
# Linux
# ----------------------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*

# ----------------------------------------------------------------------------
# Windows
# ----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
apps/src/sage/apps/medical_diagnosis/data/processed/*
